/*
1) This script scans ad placements across the entire account (including Performance Max).
   It strictly filters ONLY websites, completely ignoring YouTube channels/videos and mobile apps 
   to prevent Google Ads API errors.
2) Exclusions are added to the shared list "PlacementCleanerList_New".
*/

var exclude = [
    // --- Games, Gambling ---
    'gta', 'dota', 'minecraft', 'igry', 'igra', 'igri', 'game', 'casino', 'slot', 
    'poker', 'bonus', 'stavk', 'betting', 'gamer', 'geym', 'play-', 'quiz', 'test-',
