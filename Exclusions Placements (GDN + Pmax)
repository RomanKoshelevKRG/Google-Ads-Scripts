    'kids', 'children', 'baby', 'mom', 'mama', 'parent', 'malysh', 'rebenok', 
    'mult', 'cartoon', 'anime', 'raskrask', 'detskiy', 'doshkol', 'shkol', 
    'ucheb', 'gdz', 'zno', 'student', 'resheb', 'referat', 'spongebob', 'barbie', 
    'майнкрафт',
    
    // --- Entertainment, Media, File Sharing ---
    'film', 'video', 'movie', 'kino', 'serial', 'tv', 'smotret', 'dyvytys', 
    'online-', 'onlain', 'mp3', 'fb2', 'book', 'download', 'torrent', 'radio', 
